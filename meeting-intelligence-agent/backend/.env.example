# Application
APP_NAME=Meeting Intelligence Agent
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3002

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meeting_intel
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_EXPIRY=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Groq (Whisper transcription — REQUIRED)
# Get key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# Anthropic Claude (NLP summaries — REQUIRED)
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Pinecone (Vector DB)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=meeting-intelligence

# Google (Calendar + Meet bot — REQUIRED for bot features)
# Create OAuth credentials at: https://console.cloud.google.com
# Authorised redirect URI must be: http://localhost:8002/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8002/api/v1/auth/google/callback

# Microsoft (Outlook — optional)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8002/api/v1/auth/microsoft/callback

# Zoom
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_BOT_JWT=your-zoom-bot-jwt

# Slack
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Linear
LINEAR_API_KEY=your-linear-api-key
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret

# Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-jira-email
JIRA_API_TOKEN=your-jira-api-token

# Asana
ASANA_ACCESS_TOKEN=your-asana-access-token

# Notion
NOTION_API_KEY=your-notion-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@meetingintel.ai

# Storage
STORAGE_TYPE=local  # local, s3, gcs
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=meeting-recordings
AWS_REGION=us-east-1

# Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Meeting Recording
MAX_RECORDING_DURATION_HOURS=4
RECORDING_RETENTION_DAYS=90
AUTO_DELETE_RECORDINGS=True

# Features
ENABLE_REAL_TIME_ALERTS=True
ENABLE_PRE_MEETING_BRIEFS=True
ENABLE_ANALYTICS=True
ENABLE_AUTO_JOIN=True

# CORS
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3001,http://localhost:3000,http://localhost:8002
ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
ALLOWED_HEADERS=*
TRUSTED_HOSTS=localhost,127.0.0.1,testserver,*.meetingintel.ai

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
